rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global reusable helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true ||
        request.auth.token.email == 'mdwasimalam264@gmail.com'
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == 'mdwasimalam264@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Collection validation helpers
    function isValidNotice(data) {
      return data.title is string && data.title.size() <= 300
          && data.content is string && data.content.size() <= 20000
          && (data.category == 'general' || data.category == 'batch' || data.category == 'holiday' || data.category == 'exam')
          && data.pinned is bool
          && data.createdAt is timestamp;
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() <= 300
          && data.slug is string && data.slug.size() <= 300
          && data.content is string && data.content.size() <= 50000
          && data.summary is string && data.summary.size() <= 1000
          && (data.category == 'exam-prep' || data.category == 'study-tips' || data.category == 'career-guide' || data.category == 'scholarship' || data.category == 'board-exams' || data.category == 'gov-exams')
          && data.imageUrl is string && data.imageUrl.size() <= 2000
          && data.author is string && data.author.size() <= 128
          && data.views is int
          && data.createdAt is timestamp;
    }

    function isValidAdmissionRequest(data) {
      return data.name is string && data.name.size() <= 128
          && data.phone is string && data.phone.size() <= 20
          && data.courseId is string && data.courseId.size() <= 64
          && (data.status == 'pending' || data.status == 'contacted' || data.status == 'approved' || data.status == 'rejected')
          && data.createdAt is timestamp;
    }

    function isValidContactMessage(data) {
      return data.name is string && data.name.size() <= 128
          && data.email is string && data.email.size() <= 128
          && data.message is string && data.message.size() <= 5000
          && (data.status == 'unread' || data.status == 'read')
          && data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      return data.apkVersion is string && data.apkVersion.size() <= 64
          && data.apkUrl is string && data.apkUrl.size() <= 2000
          && data.apkSize is string && data.apkSize.size() <= 64
          && data.releaseNotes is string && data.releaseNotes.size() <= 5000
          && data.bannerTitle is string && data.bannerTitle.size() <= 200
          && data.bannerSubtitle is string && data.bannerSubtitle.size() <= 500
          && data.whatsappUrl is string && data.whatsappUrl.size() <= 2000;
    }

    function isValidCourse(data) {
      return data.name is string && data.name.size() <= 200
          && data.target is string && data.target.size() <= 100
          && data.fee is string && data.fee.size() <= 50;
    }

    function isValidFreeResource(data) {
      return data.title is string && data.title.size() <= 300
          && (data.category == 'notes' || data.category == 'pdfs' || data.category == 'syllabus' || data.category == 'papers')
          && data.classTarget is string && data.classTarget.size() <= 100
          && data.downloadUrl is string && data.downloadUrl.size() <= 2000;
    }

    function isValidFacultyMember(data) {
      return data.name is string && data.name.size() <= 128
          && data.role is string && data.role.size() <= 128
          && data.spec is string && data.spec.size() <= 200;
    }

    function isValidTestimonial(data) {
      return data.name is string && data.name.size() <= 128
          && data.role is string && data.role.size() <= 128
          && data.text is string && data.text.size() <= 2000;
    }

    // Rules for NOTICES collection
    match /notices/{noticeId} {
      allow read: if true; // Public access
      allow create: if isAdmin() && isValidNotice(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidNotice(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['title', 'content', 'category', 'pinned', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    // Rules for BLOGS collection
    match /blogs/{blogId} {
      allow read: if true; // Public access
      allow create: if isAdmin() && isValidBlogPost(incoming()) && incoming().createdAt == request.time;
      allow update: if (isAdmin() && isValidBlogPost(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['title', 'slug', 'content', 'summary', 'category', 'imageUrl', 'author', 'views', 'updatedAt'])
      )) || (
        // Allow public views incrementation
        incoming().diff(existing()).affectedKeys().hasOnly(['views']) && incoming().views == existing().views + 1
      );
      allow delete: if isAdmin();
    }

    // Rules for ADMISSIONS collection
    match /admissions/{admissionId} {
      allow read: if isAdmin(); // Only admins can view list
      allow create: if isValidAdmissionRequest(incoming()) && incoming().status == 'pending' && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidAdmissionRequest(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'message'])
      );
      allow delete: if isAdmin();
    }

    // Rules for CONTACT MESSAGES collection
    match /messages/{messageId} {
      allow read: if isAdmin(); // Only admins can view list
      allow create: if isValidContactMessage(incoming()) && incoming().status == 'unread' && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidContactMessage(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    // Rules for SETTINGS collection
    match /settings/{docId} {
      allow read: if true; // Public parameters check
      allow create, update: if isAdmin() && isValidSettings(incoming());
      allow delete: if isAdmin();
    }

    // Rules for COURSES collection
    match /courses/{courseId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCourse(incoming());
      allow delete: if isAdmin();
    }

    // Rules for RESOURCES collection
    match /resources/{resourceId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidFreeResource(incoming());
      allow delete: if isAdmin();
    }

    // Rules for FACULTY collection
    match /faculty/{facultyId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidFacultyMember(incoming());
      allow delete: if isAdmin();
    }

    // Rules for TESTIMONIALS collection
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTestimonial(incoming());
      allow delete: if isAdmin();
    }

    // Rules for ADMINS collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
